#pragma once
#include <memory>
#include <algorithm>
#include "sprite.hpp"

using namespace std;

class Scene {
public:
    vector<unique_ptr<Sprite>> sprites;

    // Создать объект и вернуть указатель на него (чтобы менять координаты)
    Sprite* spawn(float x, float y, float w, float h) {
        auto s = make_unique<Sprite>();
        s->x = x; s->y = y; s->w = w; s->h = h;
        sprites.push_back(move(s));
        return sprites.back().get();
    }

    // Очистка мертвых объектов
    void cleanup() {
        sprites.erase(remove_if(sprites.begin(), sprites.end(), 
            [](const auto& s) { return s->pending_destruction; }), sprites.end());
    }

    // Собираем все вершины в кучу для GPU
    void updateGlobalBuffers(vector<Vertex>& v, vector<uint16_t>& i) {
        v.clear();
        i.clear();
        for (const auto& s : sprites) {
            s->pushData(v, i);
        }
    }
};
